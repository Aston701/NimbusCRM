# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/nimbus_crm"

# NextAuth
NEXTAUTH_SECRET="your-random-secret-here-run-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Email (SMTP - e.g. Gmail, SendGrid, your own mail server)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Nimbus CRM <noreply@yourdomain.com>"

# App
APP_URL="http://localhost:3000"
COMPANY_NAME="Dynamic Business Systems"
COMPANY_EMAIL="info@dynamicbusiness.co.za"
COMPANY_PHONE="+27 11 000 0000"
COMPANY_ADDRESS="Your Address, City, Province, Postal Code"
COMPANY_VAT_NO="VAT123456789"
COMPANY_REG_NO="2024/000000/07"

# File uploads (absolute path on the server)
UPLOAD_DIR="./uploads"
